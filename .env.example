# Copy this file to .env.local and fill in all values before running locally.
# ALL keys marked "required" must be set or the app will throw on startup.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=          # required
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # required
SUPABASE_SERVICE_KEY=              # required

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_USER=                        # required
ADMIN_PASSWORD=                    # required

# ── AI / Chat bot ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=                  # required — get from platform.deepseek.com
OPENROUTER_API_KEY=                # required — get from openrouter.ai

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=                    # required — get from resend.com
RESEND_FROM_EMAIL=                 # optional — defaults to noreply@vasutraders.com

# ── WhatsApp ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=       # required — e.g. 919425073114
WHATSAPP_BOT_URL=                  # optional
GREENAPI_INSTANCE_ID=              # optional — WhatsApp OTP via green-api.com
GREENAPI_TOKEN=                    # optional

# ── Branding ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_NAME=         # optional — defaults to "Vasu Traders"
